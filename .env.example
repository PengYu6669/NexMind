# ===================== 项目基础 =====================
NEXT_PUBLIC_APP_NAME="NexMind"
NEXT_PUBLIC_APP_VERSION="1.0.0-MVP"

# ===================== 数据库 =====================
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>?schema=public"

# ===================== AI API =====================
NEXT_PUBLIC_AI_DEFAULT_MODEL="doubao-seed-2-0-lite-260215"
AI_API_KEY="<YOUR_AI_API_KEY>"
AI_API_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
# 向量接口（完整路径）
AI_API_EMBEDDING_URL="https://ark.cn-beijing.volces.com/api/v3/embeddings/multimodal"
AI_MODEL_CHAT="doubao-seed-2-0-lite-260215"
AI_MODEL_SEARCH="doubao-seed-2-0-mini-260215"
AI_MODEL_SUMMARY="doubao-seed-2-0-lite-260215"
AI_MODEL_WRITER="doubao-seed-2-0-pro-260215"
AI_MODEL_EMBEDDING="doubao-embedding-vision-251215"
AI_EMBEDDING_DIMENSION=1024

# ===================== 火山 TOS =====================
VOLC_TOS_REGION="cn-beijing"
VOLC_TOS_BUCKET="<YOUR_TOS_BUCKET>"
VOLC_TOS_ACCESS_KEY="<YOUR_TOS_ACCESS_KEY>"
VOLC_TOS_SECRET_KEY="<YOUR_TOS_SECRET_KEY>"
VOLC_TOS_ENDPOINT="tos-cn-beijing.volces.com"
VOLC_TOS_PREFIX="ima-clone/files/"
VOLC_TOS_SECURE="true"

# ===================== NextClaw / MCP =====================
NEXTCLAW_MCP_ENABLED=true
SERPAPI_API_KEY="<YOUR_SERPAPI_API_KEY>"
NEXTCLAW_MCP_KNOWLEDGE_ENTRY="mcp-servers/nextclaw-bridge/run.ts"
NEXTCLAW_AUTONOMOUS_MAX_ROUNDS=1
NEXTCLAW_SEARCH_PREFER_CN=true
